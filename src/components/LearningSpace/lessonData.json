      "inputSubtext": "Write what you think will happen and why.",
      "peers": [
        { "id": "p1", "initials": "AM", "name": "Alex M.",   "avatarColor": "bg-violet-400", "text": "I think it will sink faster because the density pushes it down." },
        { "id": "p2", "initials": "SK", "name": "Sam K.",    "avatarColor": "bg-rose-400",   "text": "No change will happen — temperature might matter more." },
        { "id": "p3", "initials": "JP", "name": "Jordan P.", "avatarColor": "bg-teal-400",   "text": "If density increases beyond the liquid, it sinks." }
      ]
    },
    {
      "id": "experiment",
      "type": "experiment",
      "label": "Experiment",
      "stepNumber": 3,
      "totalSteps": 6,
